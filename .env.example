# ===== OpenAI =====
# https://platform.openai.com/api-keys で取得
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxx
# 使用モデル（任意。未設定時は gpt-4o-mini）
OPENAI_MODEL=gpt-4o-mini

# ===== Notion =====
# https://www.notion.so/my-integrations で内部インテグレーションを作成して取得
NOTION_TOKEN=ntn_xxxxxxxxxxxxxxxxxxxxxxxx
# 対象データベースのID（DBを開いたURLの32文字）
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ===== 天気 / 波（Open-Meteo）=====
# Open-Meteo は APIキー不要・非営利/商用利用可・自動取得可。
# 下記2つは「キー方式のAPIに差し替えたい場合」だけ使用する任意項目。
# 既定の Open-Meteo 実装では未設定で問題ありません。
WEATHER_API_KEY=
WAVE_API_KEY=

# ===== 楽天トラベル 空室検索API（任意）=====
# 未設定でもサイトは動作します（周辺の宿の「空室・料金」表示のみ無効になります）。
# https://webservice.rakuten.co.jp/app/create でアプリを登録し、
# https://webservice.rakuten.co.jp/app/list で以下2つを確認してください。
# ※ accessKey は必須項目です（applicationId だけでは呼び出せません）
RAKUTEN_APPLICATION_ID=
RAKUTEN_ACCESS_KEY=
# 楽天アフィリエイトID（任意）。設定すると予約リンクがアフィリエイト経由になります。
RAKUTEN_AFFILIATE_ID=

# ===== Cron 保護 =====
# Vercel Cron から /api/cron を叩く際の共有シークレット。
# Vercel の環境変数にも同じ値を設定してください。
CRON_SECRET=change-me-to-a-long-random-string

# ===== 対象地点（任意・未設定時はヒスイ海岸の既定座標）=====
# 富山県朝日町 ヒスイ海岸 付近
HISUI_LATITUDE=36.945
HISUI_LONGITUDE=137.545
# タイムゾーン
HISUI_TIMEZONE=Asia/Tokyo
